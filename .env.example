# ----------------------------------------------------------------------------
# Souls Align — environment variables
# Copy to `.env` and fill in. Local dev runs with the defaults shown.
# ----------------------------------------------------------------------------

# Database.
#   Local dev uses SQLite (prisma/schema.prisma) — the default below. Do NOT put
#   a Postgres URL here or local dev will break (SQLite client can't connect).
#
#   PRODUCTION (set these in Vercel, not in this local file):
#     DATABASE_URL — Supabase POOLED URL (port 6543, ?pgbouncer=true); app runtime
#     DIRECT_URL   — Supabase DIRECT URL (port 5432); used by prisma migrate deploy
#   The prod schema (prisma/prod/schema.prisma) references both; vercel-build
#   runs the migration automatically.
DATABASE_URL="file:./dev.db"

# Session signing secret. Generate a strong one for production:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_SECRET="replace-with-a-long-random-string"

# Anthropic API — SERVER-SIDE ONLY. Never expose to the client.
# Leave blank to use the graceful in-character fallback in local dev.
ANTHROPIC_API_KEY=""
# Model used for in-character AI chat (defaults to Haiku for speed/cost).
CHAT_MODEL="claude-haiku-4-5-20251001"

# Photo storage adapter: "local" or "supabase".
STORAGE_DRIVER="local"

# Supabase Storage (production). Required when STORAGE_DRIVER=supabase.
SUPABASE_URL=""
SUPABASE_SERVICE_ROLE_KEY=""
SUPABASE_STORAGE_BUCKET="photos"

# PostHog analytics (optional). NEXT_PUBLIC_ vars are exposed to the client.
NEXT_PUBLIC_POSTHOG_KEY=""
NEXT_PUBLIC_POSTHOG_HOST="https://us.i.posthog.com"

# Developer/test mode. When "true" (and NOT a production build), adds a
# "Test chat" button on profiles that force-matches instantly, and auto-grants
# a couple of mutual matches on login — so AI chat can be exercised without the
# normal mutual-interest requirement. NEVER set this in production.
NEXT_PUBLIC_TEST_MODE="false"
