// AUTO-GENERATED from prisma/schema.prisma by scripts/gen-prod-schema.mjs.
// Do not edit by hand. Run `npm run prod:schema` after changing the dev schema.

// Souls Align — data model.
//
// Local dev uses SQLite for zero-setup. To move to Supabase/Postgres in
// production, change `provider` to "postgresql" and point DATABASE_URL at the
// Supabase connection string (see DEPLOYMENT.md). The schema is intentionally
// portable: no native enums, no scalar arrays — strings + a JSON-encoded
// interests field — so the swap is a one-line change.

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String

  // Profile (completed during onboarding)
  name      String?
  bio       String?
  essence   String? // one-line "essence" shown on cards
  interests String   @default("[]") // JSON-encoded string[]
  heightCm  Int?

  // Birth data (anchors every alignment; locked after verification)
  dob         DateTime?
  birthHour   Int?
  birthMinute Int?
  birthPlace  String?
  birthLat    Float?
  birthLon    Float?

  // Current/residential location (for proximity matching; editable anytime,
  // distinct from birth place which anchors the astrology and locks).
  locationLabel String?
  locationLat   Float?
  locationLon   Float?

  // Preferences & gating
  gender       String? // woman | man | nonbinary
  interestedIn String? // women | men | everyone
  connection   String? // romance | friendship | both

  // Derived destiny reading (computed at onboarding / on birth-data change)
  sunSign      String?
  moonSign     String?
  risingSign   String?
  sunElement   String? // Fire | Earth | Air | Water
  baziElement  String? // Wood | Fire | Earth | Metal | Water
  zodiacAnimal String?

  // Account state
  plan               String  @default("aligned") // aligned | aligned_plus | destined
  verified           Boolean @default(false)
  birthLocked        Boolean @default(false)
  isSeed             Boolean @default(false)
  incognito          Boolean @default(false)
  onboardingComplete Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  photos           Photo[]
  interestsSent    Interest[] @relation("InterestFrom")
  interestsGot     Interest[] @relation("InterestTo")
  messagesSent     Message[]  @relation("MsgFrom")
  messagesGot      Message[]  @relation("MsgTo")
  blocksMade       Block[]    @relation("Blocker")
  blocksGot        Block[]    @relation("Blocked")
  reportsMade      Report[]   @relation("Reporter")
  reportsGot       Report[]   @relation("Reported")
}

model Photo {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // `url` is the display-optimized (downscaled, UNcropped) image shown in the
  // UI. `originalUrl` is the full-resolution upload, kept so a photo can be
  // re-cropped later without re-uploading. `crop` is JSON crop settings
  // (percent rect + zoom + aspect) applied on display via CSS transforms.
  url         String
  originalUrl String?
  crop        String?

  sort      Int     @default(0)
  isPrimary Boolean @default(false)

  createdAt DateTime @default(now())

  @@index([userId])
}

// Expression of interest ("choosing" someone / a chat request).
// status: pending (awaiting the recipient) | accepted | declined.
// A mutual pair (both directions present, not declined) is an active chat.
model Interest {
  id        String   @id @default(cuid())
  fromId    String
  toId      String
  from      User     @relation("InterestFrom", fields: [fromId], references: [id], onDelete: Cascade)
  to        User     @relation("InterestTo", fields: [toId], references: [id], onDelete: Cascade)
  status    String   @default("pending")
  createdAt DateTime @default(now())

  @@unique([fromId, toId])
  @@index([toId])
}

model Message {
  id     String @id @default(cuid())
  fromId String
  toId   String
  from   User   @relation("MsgFrom", fields: [fromId], references: [id], onDelete: Cascade)
  to     User   @relation("MsgTo", fields: [toId], references: [id], onDelete: Cascade)
  body   String
  // Stable key for a conversation pair (sorted ids joined by ":").
  threadKey String
  createdAt DateTime @default(now())

  @@index([threadKey])
}

model Block {
  id        String   @id @default(cuid())
  blockerId String
  blockedId String
  blocker   User     @relation("Blocker", fields: [blockerId], references: [id], onDelete: Cascade)
  blocked   User     @relation("Blocked", fields: [blockedId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([blockerId, blockedId])
  @@index([blockedId])
}

model Report {
  id         String   @id @default(cuid())
  reporterId String
  reportedId String? // null for a general "report an issue"
  reporter   User     @relation("Reporter", fields: [reporterId], references: [id], onDelete: Cascade)
  reported   User?    @relation("Reported", fields: [reportedId], references: [id], onDelete: SetNull)
  reason     String
  detail     String?
  createdAt  DateTime @default(now())
}
